BOT_TOKEN=8584514044:AAGchUSFmU7x89m4ax-l6toXkYn8f-S-Y60

# Multi-backend AI configuration
# Priority order: ollama (local), huggingface (free API), groq (free API)
BACKENDS=ollama,huggingface,groq

# Ollama (local - fastest, no internet needed)
OLLAMA_MODEL=llama3.2:1b
OLLAMA_NUM_CTX=512
OLLAMA_NUM_THREADS=8

# Hugging Face Inference API (free tier 30k tokens/month)
HF_API_TOKEN=YOUR_HF_TOKEN_HERE
HF_MODEL=google/flan-t5-large

# Groq (free API, fast)
GROQ_API_KEY=YOUR_GROQ_TOKEN_HERE
GROQ_MODEL=llama3-8b-8192

# Generation settings
MAX_TOKENS=120
TEMPERATURE=0.3
TOP_P=0.9
TOP_K=30

# Conversation settings
MAX_HISTORY=5

# Cache settings (in-memory)
ENABLE_CACHE=true
CACHE_TTL=300  # seconds